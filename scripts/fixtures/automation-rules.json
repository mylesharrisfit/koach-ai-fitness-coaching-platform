      "actions": [
        { "type": "award_badge", "value": "streak_7" },
        { "type": "send_message", "message": "{streak}-check-in streak, {client_name}!" }
      ]
    },
    {
      "key": "inactive_rule",
      "shape": "trigger",
      "name": "Inactive rule (must never run)",
      "is_active": false,
      "trigger_type": "no_checkin",
      "trigger_value": 1,
      "actions": [{ "type": "send_message", "message": "should not send" }]
    }
  ],
