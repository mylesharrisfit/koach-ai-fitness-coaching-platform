{
  "_comment": "Automation rehearsal fixture (Step 4.3). Covers BOTH rule shapes plus edge cases. Dates are relative offsets (days ago) resolved by the harness against a fixed `now`, so the rehearsal is deterministic.",
  "rules": [
    {
      "key": "legacy_missed_checkin",
      "shape": "condition",
      "name": "Legacy: Missed check-in",
      "is_active": true,
      "condition_type": "missed_checkin",
      "condition_threshold": 10,
      "action_type": "notify_coach",
      "action_message": "Legacy rule: {client_name} hasn't checked in."
    },
    {
      "key": "legacy_low_adherence",
      "shape": "condition",
      "name": "Legacy: Low adherence",
