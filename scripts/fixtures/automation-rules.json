      "action_type": "send_message",
      "action_message": "Legacy: {client_name}, let's talk adherence."
    },
    {
      "key": "new_no_checkin",
      "shape": "trigger",
      "name": "New: No check-in nudge",
      "is_active": true,
      "trigger_type": "no_checkin",
      "trigger_value": 10,
      "actions": [
        { "type": "send_message", "message": "Hey {client_name}, missing your check-ins!" },
        { "type": "flag_at_risk" }
      ]
    },
    {
      "key": "new_streak_badge",
      "shape": "trigger",
      "name": "New: Streak badge",
      "is_active": true,
      "trigger_type": "streak",
