{
  "name": "AIConversation",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "Client ID this conversation is about"
    },
    "client_name": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "description": "First user message truncated"
    },
    "description": {
      "type": "string",
      "description": "Optional summary or notes about this conversation",
      "maxLength": 1000
    },
    "messages": {
      "type": "array",
      "description": "Array of message objects",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.client_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}