      "type": "string"
    },
    "rule_name": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "triggered_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions_taken": {
      "type": "string"
    }
  },
