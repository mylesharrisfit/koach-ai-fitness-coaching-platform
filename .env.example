# ── Auth provider switch (Migration Step 3a) ────────────────────────────────
# 'base44' (default) keeps the legacy hosted-redirect login; 'supabase' turns
# on the in-app Supabase Auth login/signup pages. Auth is app-wide — this one
# flag flips the whole shell.
VITE_AUTH_PROVIDER=base44

# ── Supabase (frontend, Steps 2–3) ──────────────────────────────────────────
# Required once VITE_AUTH_PROVIDER=supabase, and for any page cut over to the
# Supabase data facade. Anon key only — never the service role in frontend env.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Legacy Base44 (unchanged; used while VITE_AUTH_PROVIDER=base44) ──────────
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=

# ── Edge Function secrets (server-side only; set via `supabase secrets set`) ─
# NOT VITE_-prefixed — these must never reach the browser bundle.
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY  (auto-injected
#     for deployed functions)
#   SUPABASE_JWT_SECRET  — signs the short-lived portal JWT (validateInviteToken)
#   APP_URL              — base URL used to build the /client-setup invite link
