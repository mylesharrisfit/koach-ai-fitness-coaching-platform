# ── Supabase (frontend) ─────────────────────────────────────────────────────
# Required. The app authenticates and reads/writes all data through Supabase.
# Anon key only — never the service role in frontend env (it ships in the
# browser bundle). Both are read at BUILD time by Vite and inlined.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Edge Function secrets (server-side only; set via `supabase secrets set`) ─
# NOT VITE_-prefixed — these must never reach the browser bundle.
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY  (auto-injected
#     for deployed functions)
#   SUPABASE_JWT_SECRET  — signs the short-lived portal JWT (validateInviteToken)
#   APP_URL              — base URL used to build the /client-setup invite link

# ── One-time data migration only (npm run migrate:base44) ───────────────────
# Used by scripts/migrate-base44-to-supabase.mjs to read your existing data out
# of Base44. Not used by the app at runtime — leave unset after migrating.
#   BASE44_APP_ID
#   BASE44_API_KEY
